# Lifestyle Medicine Coaching App - Environment Variables
# Copy this file to .env and fill in your API key

# For AI coaching features (choose one):
ANTHROPIC_API_KEY=your-anthropic-api-key-here
# OPENAI_API_KEY=your-openai-api-key-here

# LLM Provider: "anthropic" or "openai"
LLM_PROVIDER=anthropic
# Optional override; defaults to the current supported balanced model.
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Demo mode (quick demo account + auto-seeding). Keep false in production.
DEMO_MODE=false

# Optional deployment bootstrap. Use environment variables or Streamlit Secrets;
# never commit real credentials. Increment each revision only when that one-time
# action should run again.
# BOOTSTRAP_ADMIN_USERNAME=your-admin-username
# BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-strong-password
# BOOTSTRAP_ADMIN_DISPLAY_NAME=Administrator
# BOOTSTRAP_ADMIN_REVISION=admin-credentials-v1
# ACCOUNT_RESET_REVISION=account-reset-v1

# Strava OAuth (all three values are required to enable Strava).
# Generate STRAVA_TOKEN_KEY with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
STRAVA_CLIENT_ID=your-strava-client-id-here
STRAVA_CLIENT_SECRET=your-strava-client-secret-here
STRAVA_TOKEN_KEY=replace-with-generated-fernet-key
